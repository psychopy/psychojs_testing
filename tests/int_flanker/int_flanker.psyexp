      <CodeComponent name="flanker_code">
        <Param name="Before Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Before JS Experiment" updates="constant" val="var flankerLayout;" valType="extendedCode"/>
        <Param name="Begin Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="Begin JS Experiment" updates="constant" val="flankerLayout = Layout.init(psychoJS, [&amp;#10;  {stim: flanker_left, anchor: Layout.midLeft, pos: [0, -0.25], width: 0.3},  &amp;#10;  {stim: flanker_right, anchor: Layout.midRight, pos: [0, -0.25], width: 0.3},&amp;#10;  {stim: flanker_image, anchor: Layout.top, pos: [0, -0.25]},&amp;#10;  {stim: flanker_fixation, anchor: Layout.top, pos: [0, -0.25]}&amp;#10;]);&amp;#10;" valType="extendedCode"/>
        <Param name="Begin JS Routine" updates="constant" val="// Setup a layout&amp;#10;document.body.setAttribute('data-report', 'flanker_trial');&amp;#10;document.body.setAttribute('data-info', correct_response);&amp;#10;flankerLayout();&amp;#10;// If we're running on keyboard, make slideshow_next and slideshow_previous transparent&amp;#10;if (deviceType === 'kb') {&amp;#10;    flanker_left.opacity = 0;&amp;#10;    flanker_right.opacity = 0;&amp;#10;}" valType="extendedCode"/>
        <Param name="Begin Routine" updates="constant" val="" valType="extendedCode"/>
        <Param name="Code Type" updates="None" val="JS" valType="str"/>
        <Param name="Each Frame" updates="constant" val="" valType="extendedCode"/>
        <Param name="Each JS Frame" updates="constant" val="flankerLayout();&amp;#10;" valType="extendedCode"/>
        <Param name="End Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="End JS Experiment" updates="constant" val="" valType="extendedCode"/>
        <Param name="End JS Routine" updates="constant" val="" valType="extendedCode"/>
        <Param name="End Routine" updates="constant" val="" valType="extendedCode"/>
        <Param name="disabled" updates="None" val="False" valType="bool"/>
        <Param name="name" updates="None" val="flanker_code" valType="code"/>
      </CodeComponent>
